FROM fedora:41

RUN dnf install -y \
    rpm-build \
    rpmdevtools \
    java-17-openjdk-devel \
    ant \
    gettext \
    systemd-rpm-macros \
    curl \
    bzip2 \
    && dnf clean all

# Setup rpmbuild tree
RUN rpmdev-setuptree

# Copy in packaging files
COPY SPEC/ /build/SPEC/
COPY SOURCES/ /build/SOURCES/
COPY scripts/ /build/scripts/

RUN chmod +x /build/scripts/*.sh

WORKDIR /build

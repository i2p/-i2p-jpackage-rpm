# I2P Router Configuration — default for RPM package (headless server)
# This file is copied to /var/lib/i2p/router.config on first run.
# See https://geti2p.net/en/docs/spec/configuration

# Router console binds to localhost only
i2cp.disableInterface=true
i2np.upnp.enable=true

# Bandwidth limits (KBps) — conservative defaults, user should increase
i2np.bandwidth.inboundKBytesPerSecond=300
i2np.bandwidth.outboundKBytesPerSecond=300
i2np.bandwidth.inboundBurstKBytesPerSecond=400
i2np.bandwidth.outboundBurstKBytesPerSecond=400

# Share bandwidth (percentage offered to network)
router.sharePercentage=80

# Disable auto-update (package manager handles updates)
router.updateDisabled=true

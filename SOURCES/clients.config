# I2P Client Applications Configuration — default for RPM package
# This file is copied to /var/lib/i2p/clients.config on first run.

# Router console (web UI)
clientApp.0.main=net.i2p.router.web.RouterConsoleRunner
clientApp.0.name=I2P Router Console
clientApp.0.args=7657 127.0.0.1 ./webapps/
clientApp.0.startOnLoad=true
clientApp.0.delay=0

# SAM Bridge
clientApp.1.main=net.i2p.sam.SAMBridge
clientApp.1.name=SAM Application Bridge
clientApp.1.args=sam.keys 127.0.0.1 7656 i2cp.tcp.host=127.0.0.1 i2cp.tcp.port=7654
clientApp.1.startOnLoad=true
clientApp.1.delay=5

# HTTP Proxy
clientApp.2.main=net.i2p.i2ptunnel.TunnelControllerGroup
clientApp.2.name=Application tunnels
clientApp.2.args=/var/lib/i2p/i2ptunnel.config
clientApp.2.startOnLoad=true
clientApp.2.delay=10

# I2CP listener (for external client apps)
clientApp.3.main=net.i2p.router.client.ClientListenerRunner
clientApp.3.name=I2CP
clientApp.3.args=7654
clientApp.3.startOnLoad=false
clientApp.3.delay=0

# BOB
clientApp.4.main=net.i2p.BOB.BOB
clientApp.4.name=BOB Application Bridge
clientApp.4.args=
clientApp.4.startOnLoad=false
clientApp.4.delay=20
